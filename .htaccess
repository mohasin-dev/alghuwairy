<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive individual files
    RewriteRule ^(?:\.env|artisan|composer\.(?:json|lock)|package\.json|phpunit\.xml|vite\.config\.js)$ - [F,L,NC]

    # Block sensitive Laravel directories
    # Do not block "storage" here because /storage is publicly accessible
    RewriteRule ^(?:app|bootstrap|config|database|resources|routes|tests|vendor)(?:/|$) - [F,L,NC]

    # Route public storage files correctly
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]

    # Prevent duplicate rewriting
    RewriteRule ^public(?:/|$) - [L]

    # Route everything else through the public directory
    RewriteRule ^(.*)$ public/$1 [L]

</IfModule>
