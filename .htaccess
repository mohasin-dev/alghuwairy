<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive Laravel files and directories
    RewriteRule ^(?:\.env|artisan|composer\.(?:json|lock)|package\.json|phpunit\.xml|vite\.config\.js)$ - [F,L,NC]
    RewriteRule ^(?:app|bootstrap|config|database|resources|routes|storage|tests|vendor)(?:/|$) - [F,L,NC]

    # Do not rewrite requests already starting with /public
    RewriteRule ^public(?:/|$) - [L]

    # Send all other requests to Laravel's public directory
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>